  "bin": {
    "mcp-trustcard": "bin/mcp-trustcard.js"
  },
  "files": [
    "bin",
    "lib"
  ],
  "scripts": {
    "scan:all": "node bin/mcp-trustcard.js scan --batch servers/official.json --json-out results.json",
    "test": "node --test \"test/*.test.js\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "trust",
    "provenance",
    "tool-identity",
    "supply-chain",
    "audit",
    "healthcheck",
    "agents"
  ],
