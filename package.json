{
  "name": "mcp-trustcard",
  "version": "2.3.0",
  "description": "Cryptographic trust infrastructure for MCP servers — content-addressed tool identity, signed manifests, TOFU pinning, capability descriptors, a two-gate invocation policy, signed+chained receipts, publisher key rotation, and per-agent OAuth 2.1 auth scope enforcement. Also the \"npm audit\" health-check / public trust card for every Model Context Protocol server.",
  "type": "module",
  "bin": {
    "mcp-trustcard": "bin/mcp-trustcard.js",
    "mcp-proxy": "bin/mcp-proxy.js",
    "mcp-http-proxy": "bin/mcp-http-proxy.js"
  },
  "exports": {
    ".": "./lib/guard.js",
    "./lib/*": "./lib/*.js"
  },
  "files": [
    "bin",
    "lib",
    "docs",
    "examples",
    "test",
    "!docs/reddit-master-plan.md"
  ],
  "scripts": {
    "scan:all": "node bin/mcp-trustcard.js scan --batch servers/official.json --json-out results.json",
    "test": "node --test \"test/*.test.js\"",
    "test:fast": "node --test test/checks.test.js test/danger-detector.test.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "trust",
    "provenance",
    "tool-identity",
    "supply-chain",
    "audit",
    "healthcheck",
    "agents",
    "oauth",
    "authorization",
    "scopes"
  ],
  "license": "MIT",
  "author": "davidnichols-ops",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidnichols-ops/trustcard.git"
  },
  "bugs": {
    "url": "https://github.com/davidnichols-ops/trustcard/issues"
  },
  "homepage": "https://github.com/davidnichols-ops/trustcard#readme",
  "engines": {
    "node": ">=18"
  }
}
